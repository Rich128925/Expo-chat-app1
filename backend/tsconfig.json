{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",   
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node16" 
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}